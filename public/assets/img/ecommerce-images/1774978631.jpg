}

.video-background {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transform: translate(-50%, -50%);
}

.desktop-video {
  display: block;
}

.mobile-video {
  display: none;
}

@media (max-width: 768px) {
